# Production env for docker-compose. Copy to .env and fill values:
#   cp .env.example .env
# Generate JWT_SECRET with: openssl rand -hex 32

# Host port binding — disesuaikan dengan port yang masih kosong di VPS kamu.
# Default bind ke 127.0.0.1 supaya hanya nginx host yang bisa akses (aman).
# Kalau mau expose ke public langsung, set API_BIND=0.0.0.0 / WEB_BIND=0.0.0.0.
WEB_PORT=9737
WEB_BIND=127.0.0.1
API_PORT=9787
API_BIND=127.0.0.1

# Domain & URLs (sesuaikan dengan domain yang kamu pasang di nginx)
NEXT_PUBLIC_API_URL=https://klipin.id
PUBLIC_APP_URL=https://klipin.id
CORS_ORIGINS=["https://klipin.id"]

# Auth
JWT_SECRET=REPLACE_WITH_64_HEX_CHARS

# AI services
ANTHROPIC_API_KEY=sk-ant-...
REPLICATE_API_TOKEN=r8_...

# Anthropic geo-block workaround (only if VPS region tidak disupport — HK, ID, CN, RU, IR).
# Deploy infra/anthropic-proxy/worker.js sebagai Cloudflare Worker, lalu set:
# ANTHROPIC_BASE_URL=https://your-worker.your-acct.workers.dev
# ANTHROPIC_PROXY_SECRET=optional-shared-secret-if-worker-pakai-PROXY_SECRET

# Payment (sandbox first, flip MIDTRANS_IS_PRODUCTION later)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
LIFETIME_PRICE_IDR=129000

# Resource limits
MAX_INPUT_MINUTES=60

# yt-dlp cookies (uncomment kalau YouTube minta PO Token / kena bot detection).
# Lihat DEPLOY.md "Setup cookies untuk yt-dlp" untuk cara export.
# YOUTUBE_COOKIES_FILE=/app/cookies.txt

# Models (override only if you know what you're doing — leave commented to
# use code defaults, which point to current working models)
# WHISPER_MODEL=vaibhavs10/incredibly-fast-whisper
# CLAUDE_MODEL=claude-sonnet-4-6

# Hanya dipakai kalau pakai overlay docker-compose.caddy.yml
DOMAIN=klipin.id
