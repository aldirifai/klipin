# Production env for docker-compose. Copy to .env and fill values:
#   cp .env.example .env
# Generate JWT_SECRET with: openssl rand -hex 32

# Host port binding — disesuaikan dengan port yang masih kosong di VPS kamu.
# Default bind ke 127.0.0.1 supaya hanya nginx host yang bisa akses (aman).
# Kalau mau expose ke public langsung, set API_BIND=0.0.0.0 / WEB_BIND=0.0.0.0.
WEB_PORT=9737
WEB_BIND=127.0.0.1
API_PORT=9787
API_BIND=127.0.0.1

# Domain & URLs (sesuaikan dengan domain yang kamu pasang di nginx)
NEXT_PUBLIC_API_URL=https://klipin.id
PUBLIC_APP_URL=https://klipin.id
CORS_ORIGINS=["https://klipin.id"]

# Auth
JWT_SECRET=REPLACE_WITH_64_HEX_CHARS

# AI services
ANTHROPIC_API_KEY=sk-ant-...
REPLICATE_API_TOKEN=r8_...

# Payment (sandbox first, flip MIDTRANS_IS_PRODUCTION later)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
LIFETIME_PRICE_IDR=129000

# Resource limits
MAX_INPUT_MINUTES=60

# Models (override only if you know what you're doing)
WHISPER_MODEL=openai/whisper
CLAUDE_MODEL=claude-sonnet-4-6

# Hanya dipakai kalau pakai overlay docker-compose.caddy.yml
DOMAIN=klipin.id
